# ── LLM Provider (any model supported by LiteLLM) ─────────────────────────
# Docs: https://docs.litellm.ai/docs/providers
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=...
# OLLAMA_API_BASE=http://localhost:11434  # For local Ollama models

# Default model for the agent (LiteLLM format)
OMNI_MODEL=gpt-4o-mini

# ── WeCom Bot (Phase 2) ───────────────────────────────────────────────────
# Get credentials from https://work.weixin.qq.com/
WECOM_CORP_ID=ww...
WECOM_APP_SECRET=
WECOM_AGENT_ID=1000002
WECOM_TOKEN=your-callback-token
WECOM_ENCODING_AES_KEY=your-43-char-encoding-aes-key

# ── Feishu / Lark Bot (飞书) ──────────────────────────────────────────────
# Get credentials from https://open.feishu.cn/
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=your-verification-token
# Leave empty to disable event encryption; set to enable AES decryption
FEISHU_ENCRYPT_KEY=

# ── Server Configuration ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Rate Limiting ─────────────────────────────────────────────────────────
# Max requests per minute per user/IP
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_PERIOD=60

# ── Logging ───────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# LITELLM_LOG=DEBUG

# ── Misc ──────────────────────────────────────────────────────────────────
# Enable browser tool (true/false)
BROWSER_TOOL_ENABLED=true
