# ── LLM Provider (any model supported by LiteLLM) ─────────────────────────
# Docs: https://docs.litellm.ai/docs/providers
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=...

# Default model for the agent
OMNI_MODEL=gpt-4o-mini

# ── WeCom Bot (Phase 2) ───────────────────────────────────────────────────
WECOM_CORP_ID=ww...
WECOM_APP_SECRET=
WECOM_AGENT_ID=1000002
WECOM_TOKEN=your-callback-token
WECOM_ENCODING_AES_KEY=your-43-char-encoding-aes-key

# ── Feishu / Lark Bot (飞书) ──────────────────────────────────────────────
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=your-verification-token
# Leave empty to disable event encryption; set to enable AES decryption
FEISHU_ENCRYPT_KEY=

# ── Misc ──────────────────────────────────────────────────────────────────
# LITELLM_LOG=DEBUG
