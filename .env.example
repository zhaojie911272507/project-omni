# ── LLM Provider (any model supported by LiteLLM) ─────────────────────────
# Docs: https://docs.litellm.ai/docs/providers
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=...
# OLLAMA_API_BASE=http://localhost:11434  # For local Ollama models

# Default model for the agent (LiteLLM format)
OMNI_MODEL=gpt-4o-mini

# ── WeCom Bot (Phase 2) ───────────────────────────────────────────────────
# Get credentials from https://work.weixin.qq.com/
WECOM_CORP_ID=ww...
WECOM_APP_SECRET=
WECOM_AGENT_ID=1000002
WECOM_TOKEN=your-callback-token
WECOM_ENCODING_AES_KEY=your-43-char-encoding-aes-key

# ── Feishu / Lark Bot (飞书) ──────────────────────────────────────────────
# Get credentials from https://open.feishu.cn/
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=your-verification-token
# Leave empty to disable event encryption; set to enable AES decryption
FEISHU_ENCRYPT_KEY=

# ── Telegram Bot ──────────────────────────────────────────────────────────
# Get credentials from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── Slack Bot ──────────────────────────────────────────────────────────────
# Get credentials from https://api.slack.com/
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=  # For Socket Mode (optional)

# ── Discord Bot ───────────────────────────────────────────────────────────
# Get credentials from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=

# ── Server Configuration ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Rate Limiting ─────────────────────────────────────────────────────────
# Max requests per minute per user/IP
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_PERIOD=60

# ── Logging ──────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# LITELLM_LOG=DEBUG

# ── Misc ──────────────────────────────────────────────────────────────────
# Enable browser tool (true/false)
BROWSER_TOOL_ENABLED=true

# ── Database / Memory ─────────────────────────────────────────────────────
# SQLite database path for conversation history
DB_PATH=./data/omni.db

# ── Knowledge Base / RAG ───────────────────────────────────────────────────
# ChromaDB persistence directory
CHROMA_PATH=./data/chroma
# Default collection name for knowledge base
CHROMA_COLLECTION=omni knowledge

# ── Voice / TTS ────────────────────────────────────────────────────────────
# Edge TTS voice (see https://speech.microsoft.com/catalog/ProductVoice)
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# ── Code Sandbox ──────────────────────────────────────────────────────────
# Enable sandbox execution (true/false)
SANDBOX_ENABLED=true

# ── Scheduler ─────────────────────────────────────────────────────────────
# Enable scheduler (true/false)
SCHEDULER_ENABLED=false

# ── Web UI ─────────────────────────────────────────────────────────────────
# Frontend port (for development)
WEB_UI_PORT=5173

# ── MCP Servers ───────────────────────────────────────────────────────────
# Comma-separated list of MCP server commands
# Example: "npx -y @modelcontextprotocol/server-filesystem ./data,mcp run github --token $GITHUB_TOKEN"
MCP_SERVERS=